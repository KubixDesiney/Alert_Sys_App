{
  "rules": {
    "alerts": {
      ".read": "auth != null",
      ".write": "auth != null",
      ".indexOn": ["usine", "status", "superviseurId", "assistantId", "type", "convoyeur", "poste", "push_sent"],
      "$alertId": {
        ".read": "auth != null",
        ".write": "auth != null",
        "aiHistory": {
          ".read": "auth != null",
          ".write": "auth != null",
          "$event": {
            ".read": "auth != null",
            ".write": "auth != null"
          }
        }
      }
    },
    "ai_decisions": {
      ".read": "auth != null && (root.child('users').child(auth.uid).child('role').val() === 'admin' || root.child('users').child(auth.uid).child('role').val() === 'supervisor')",
      ".write": "auth != null && root.child('users').child(auth.uid).child('role').val() === 'admin'",
      ".indexOn": ["timestamp", "alertId", "supervisorId"],
      "$decisionId": {
        ".read": "auth != null && (root.child('users').child(auth.uid).child('role').val() === 'admin' || root.child('users').child(auth.uid).child('role').val() === 'supervisor')",
        ".write": "auth != null && root.child('users').child(auth.uid).child('role').val() === 'admin'"
      }
    },
    "notifications": {
      ".read": "auth != null",
      ".write": false,
      "$userId": {
        ".read": "auth.uid === $userId || root.child('users').child(auth.uid).child('role').val() === 'admin'",
        "$notifId": {
          ".read": "auth.uid === $userId || root.child('users').child(auth.uid).child('role').val() === 'admin'",
          ".write": "auth != null && (!data.exists() || auth.uid === $userId || root.child('users').child(auth.uid).child('role').val() === 'admin')"
        }
      }
    },
    "users": {
      ".read": "auth != null",
      ".write": false,
      ".indexOn": ["role", "usine", "aiOptOut"],
      "$userId": {
        ".read": "auth.uid === $userId || root.child('users').child(auth.uid).child('role').val() === 'admin'",
        ".write": "auth != null && (auth.uid === $userId || root.child('users').child(auth.uid).child('role').val() === 'admin')"
      }
    },
    "supervisors": {
      ".read": "auth != null",
      ".write": "auth != null && root.child('users').child(auth.uid).child('role').val() === 'admin'",
      ".indexOn": ["usine", "active"]
    },
    "hierarchy": {
      ".read": "auth != null",
      ".write": "auth != null && root.child('users').child(auth.uid).child('role').val() === 'admin'",
      "$key": {
        ".read": "auth != null",
        ".write": "auth != null && root.child('users').child(auth.uid).child('role').val() === 'admin'"
      }
    },
    "collaboration_requests": {
      ".read": "auth != null && (root.child('users').child(auth.uid).child('role').val() === 'admin' || root.child('users').child(auth.uid).child('role').val() === 'supervisor')",
      ".write": "auth != null && (root.child('users').child(auth.uid).child('role').val() === 'admin' || root.child('users').child(auth.uid).child('role').val() === 'supervisor')",
      ".indexOn": ["requesterId", "status", "pmApproved", "timestamp", "alertId"],
      "$requestId": {
        ".read": "auth != null && (root.child('users').child(auth.uid).child('role').val() === 'admin' || root.child('users').child(auth.uid).child('role').val() === 'supervisor')",
        ".write": "auth != null && (root.child('users').child(auth.uid).child('role').val() === 'admin' || root.child('users').child(auth.uid).child('role').val() === 'supervisor')"
      }
    },
    "escalation_settings": {
      ".read": "auth != null && root.child('users').child(auth.uid).child('role').val() === 'admin'",
      ".write": "auth != null && root.child('users').child(auth.uid).child('role').val() === 'admin'"
    },
    "help_requests": {
      ".read": "auth != null && (root.child('users').child(auth.uid).child('role').val() === 'admin' || root.child('users').child(auth.uid).child('role').val() === 'supervisor')",
      ".write": "auth != null && (root.child('users').child(auth.uid).child('role').val() === 'admin' || root.child('users').child(auth.uid).child('role').val() === 'supervisor')",
      ".indexOn": ["alertId", "requesterId", "targetSupervisorId", "status", "timestamp"]
    },
    "pm_actions": {
      ".read": "auth != null",
      ".write": false,
      "$userId": {
        ".read": "auth.uid === $userId || root.child('users').child(auth.uid).child('role').val() === 'admin'",
        ".write": "auth != null && (auth.uid === $userId || root.child('users').child(auth.uid).child('role').val() === 'admin')"
      }
    },
    "ai_feedback": {
      ".read": "auth != null && root.child('users').child(auth.uid).child('role').val() === 'admin'",
      ".write": "auth != null && root.child('users').child(auth.uid).child('role').val() === 'admin'"
    },
    "ai_master": {
      ".read": "auth != null",
      ".write": "auth != null && root.child('users').child(auth.uid).child('role').val() === 'admin'",
      "enabled": {
        ".validate": "newData.isBoolean()"
      },
      "enabledBy": {
        ".validate": "!newData.exists() || (newData.isString() && newData.val().length > 0 && newData.val().length <= 128)"
      },
      "enabledAt": {
        ".validate": "!newData.exists() || newData.isString()"
      },
      "updatedAt": {
        ".validate": "!newData.exists() || newData.isString()"
      },
      "$other": {
        ".validate": false
      }
    },
    "factories": {
      ".read": "auth != null",
      "$factoryId": {
        ".read": "auth != null",
        "aiConfig": {
          ".read": "auth != null",
          ".write": "auth != null && root.child('users').child(auth.uid).child('role').val() === 'admin'",
          "enabled": {
            ".validate": "newData.isBoolean()"
          },
          "enabledBy": {
            ".validate": "!newData.exists() || (newData.isString() && newData.val().length > 0 && newData.val().length <= 128)"
          },
          "enabledAt": {
            ".validate": "!newData.exists() || newData.isString()"
          },
          "updatedAt": {
            ".validate": "!newData.exists() || newData.isString()"
          },
          "skippedAlertTtlMinutes": {
            ".validate": "!newData.exists() || (newData.isNumber() && newData.val() >= 1 && newData.val() <= 240)"
          },
          "$other": {
            ".validate": false
          }
        }
      }
    },
    ".read": false,
    ".write": false
  }
}
