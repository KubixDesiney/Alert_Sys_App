{
  "rules": {

    "alerts": {
      ".read": "auth != null",
      ".write": "auth != null",
      ".indexOn": [
        "usine", "status", "superviseurId", "assistantId",
        "type", "convoyeur", "poste", "assetId", "push_sent", "isEscalated"
      ],
      "$alertId": {
        ".read": "auth != null",
        ".write": "auth != null || (auth == null && !data.exists() && newData.hasChildren(['adresse','convoyeur','poste','timestamp','type','usine']) && newData.child('adresse').isString() && newData.child('convoyeur').isNumber() && newData.child('poste').isNumber() && newData.child('timestamp').isString() && newData.child('type').isString() && newData.child('usine').isString())",
        "adresse": { ".validate": "newData.isString()" },
        "convoyeur": { ".validate": "newData.isNumber()" },
        "poste": { ".validate": "newData.isNumber()" },
        "assetId": { ".validate": "!newData.exists() || newData.isString()" },
        "timestamp": { ".validate": "newData.isString()" },
        "type": { ".validate": "newData.isString()" },
        "usine": { ".validate": "newData.isString()" },
        "description": { ".validate": "!newData.exists() || newData.isString()" },
        "status": { ".validate": "!newData.exists() || newData.isString()" },
        "push_sent": { ".validate": "!newData.exists() || newData.isBoolean()" },
        "push_sending": { ".validate": "!newData.exists() || newData.isBoolean()" },
        "push_sending_at": { ".validate": "!newData.exists() || newData.isString()" },
        "push_sent_at": { ".validate": "!newData.exists() || newData.isString()" },
        "push_last_error_at": { ".validate": "!newData.exists() || newData.isString()" },
        "push_skip_reason": { ".validate": "!newData.exists() || newData.isString()" },
        "notificationSent": { ".validate": "!newData.exists() || newData.isBoolean()" },
        "isCritical": { ".validate": "!newData.exists() || newData.isBoolean()" },
        "aiHistory": {
          ".read": "auth != null",
          ".write": "auth != null"
        }
      }
    },

    "supervisor_active_alerts": {
      ".read": "auth != null",
      ".write": "auth != null",
      "$supervisorId": {
        ".read": "auth != null && (auth.uid === $supervisorId || root.child('users').child(auth.uid).child('role').val() === 'admin')",
        ".write": "auth != null && (auth.uid === $supervisorId || root.child('users').child(auth.uid).child('role').val() === 'admin')"
      }
    },

    "collaboration_alerts": {
      ".read": "auth != null",
      ".write": "auth != null",
      "$supervisorId": {
        ".read": "auth != null && (auth.uid === $supervisorId || root.child('users').child(auth.uid).child('role').val() === 'admin')",
        ".write": "auth != null && root.child('users').child(auth.uid).child('role').val() === 'admin'"
      }
    },

    "notifications": {
      ".read": "auth != null",
      ".write": "auth != null",
      "$userId": {
        ".read": "auth != null && (auth.uid === $userId || root.child('users').child(auth.uid).child('role').val() === 'admin')",
        "$notifId": {
          ".read": "auth != null && (auth.uid === $userId || root.child('users').child(auth.uid).child('role').val() === 'admin')",
          ".write": "auth != null && ((auth.uid === $userId) || root.child('users').child(auth.uid).child('role').val() === 'admin' || (root.child('users').child(auth.uid).child('role').val() === 'supervisor' && !data.exists()))"
        }
      }
    },

    "pm_actions": {
      ".read": "auth != null",
      ".write": "auth != null",
      "$userId": {
        ".read": "auth != null && (auth.uid === $userId || root.child('users').child(auth.uid).child('role').val() === 'admin')",
        ".write": "auth != null && (auth.uid === $userId || root.child('users').child(auth.uid).child('role').val() === 'admin')"
      }
    },

    "alertCounter": {
      ".read": true,
      ".write": "auth != null"
    },

    "assetCounter": {
      ".read": true,
      ".write": "auth != null && (root.child('users').child(auth.uid).child('role').val() === 'admin' || auth.token.role === 'admin')"
    },

    "assets": {
      ".read": "auth != null",
      ".write": "auth != null && (root.child('users').child(auth.uid).child('role').val() === 'admin' || auth.token.role === 'admin')",
      "$assetId": {
        ".read": "auth != null",
        ".write": "auth != null && (root.child('users').child(auth.uid).child('role').val() === 'admin' || auth.token.role === 'admin')",
        "assetId": { ".validate": "!newData.exists() || newData.isString()" },
        "name": { ".validate": "!newData.exists() || newData.isString()" },
        "factoryId": { ".validate": "!newData.exists() || newData.isString()" },
        "factoryName": { ".validate": "!newData.exists() || newData.isString()" },
        "conveyorId": { ".validate": "!newData.exists() || newData.isString()" },
        "conveyorNumber": { ".validate": "!newData.exists() || newData.isNumber()" },
        "stationId": { ".validate": "!newData.exists() || newData.isString()" },
        "stationNumber": { ".validate": "!newData.exists() || newData.isNumber()" },
        "address": { ".validate": "!newData.exists() || newData.isString()" },
        "updatedAt": { ".validate": "!newData.exists() || newData.isString()" },
        "history": {
          "$index": {
            ".validate": "newData.hasChildren(['movedAt', 'from', 'to'])"
          }
        }
      }
    },

    "users": {
      ".read": "auth != null",
      ".write": false,
      ".indexOn": ["role", "usine", "aiOptOut"],
      "$userId": {
        ".read": "auth.uid === $userId || root.child('users').child(auth.uid).child('role').val() === 'admin' || auth.token.role === 'admin'",
        ".write": "auth != null && (auth.uid === $userId || root.child('users').child(auth.uid).child('role').val() === 'admin' || auth.token.role === 'admin')",
        "currentLocation": {
          ".validate": "newData.hasChildren(['lat','lng']) && newData.child('lat').isNumber() && newData.child('lng').isNumber() && (!newData.child('updatedAt').exists() || newData.child('updatedAt').isNumber() || newData.child('updatedAt').isString())"
        }
      }
    },

    "hierarchy": {
      ".read": "auth != null",
      ".write": "auth != null && (root.child('users').child(auth.uid).child('role').val() === 'admin' || auth.token.role === 'admin')",
      ".indexOn": ["name"]
    },

    "collaboration_requests": {
      ".read": "auth != null && (root.child('users').child(auth.uid).child('role').val() === 'admin' || root.child('users').child(auth.uid).child('role').val() === 'supervisor' || auth.token.role === 'admin')",
      ".write": "auth != null && (root.child('users').child(auth.uid).child('role').val() === 'admin' || root.child('users').child(auth.uid).child('role').val() === 'supervisor' || auth.token.role === 'admin')",
      ".indexOn": ["requesterId", "status", "pmApproved", "timestamp", "alertId"]
    },

    "help_requests": {
      ".read": "auth != null && (root.child('users').child(auth.uid).child('role').val() === 'admin' || root.child('users').child(auth.uid).child('role').val() === 'supervisor' || auth.token.role === 'admin')",
      ".write": "auth != null && (root.child('users').child(auth.uid).child('role').val() === 'admin' || root.child('users').child(auth.uid).child('role').val() === 'supervisor' || auth.token.role === 'admin')",
      ".indexOn": ["alertId", "requesterId", "targetSupervisorId", "status", "timestamp"]
    },

    "escalation_settings": {
      ".read": "auth != null && (root.child('users').child(auth.uid).child('role').val() === 'admin' || auth.token.role === 'admin')",
      ".write": "auth != null && (root.child('users').child(auth.uid).child('role').val() === 'admin' || auth.token.role === 'admin')"
    },

    "supervisors": {
      ".read": "auth != null",
      ".write": "auth != null && (root.child('users').child(auth.uid).child('role').val() === 'admin' || auth.token.role === 'admin')",
      ".indexOn": ["usine", "active"]
    },

    "ai_decisions": {
      ".read": "auth != null && (root.child('users').child(auth.uid).child('role').val() === 'admin' || root.child('users').child(auth.uid).child('role').val() === 'supervisor' || auth.token.role === 'admin')",
      ".write": "auth != null && (root.child('users').child(auth.uid).child('role').val() === 'admin' || auth.token.role === 'admin')",
      ".indexOn": ["timestamp", "alertId"]
    },

    "ai_feedback": {
      ".read": "auth != null && (root.child('users').child(auth.uid).child('role').val() === 'admin' || auth.token.role === 'admin')",
      ".write": "auth != null && (root.child('users').child(auth.uid).child('role').val() === 'admin' || auth.token.role === 'admin')"
    },

    "ai_master": {
      ".read": "auth != null",
      ".write": "auth != null && (root.child('users').child(auth.uid).child('role').val() === 'admin' || auth.token.role === 'admin')"
    },

    "ai_predictions": {
      ".read": "auth != null",
      ".write": "auth != null"
    },

    "ai_briefing": {
      ".read": "auth != null",
      ".write": "auth != null"
    },

    "shifts": {
      ".read": "auth != null",
      ".write": "auth != null && (root.child('users').child(auth.uid).child('role').val() === 'admin' || auth.token.role === 'admin')",
      ".indexOn": ["startMinutes", "aiCommander"],
      "$shiftId": {
        ".read": "auth != null",
        ".write": "auth != null && (root.child('users').child(auth.uid).child('role').val() === 'admin' || auth.token.role === 'admin')",
        "name": { ".validate": "newData.isString()" },
        "startMinutes": { ".validate": "newData.isNumber() && newData.val() >= 0 && newData.val() <= 1439" },
        "endMinutes": { ".validate": "newData.isNumber() && newData.val() >= 0 && newData.val() <= 1439" },
        "maxSupervisors": { ".validate": "!newData.exists() || (newData.isNumber() && newData.val() >= 1 && newData.val() <= 50)" },
        "aiCommander": { ".validate": "!newData.exists() || newData.isBoolean()" },
        "randomize": { ".validate": "!newData.exists() || newData.isBoolean()" },
        "aiConfidence": { ".validate": "!newData.exists() || (newData.isNumber() && newData.val() >= 0 && newData.val() <= 1)" },
        "handleAssignments": { ".validate": "!newData.exists() || newData.isBoolean()" },
        "handleCollaborations": { ".validate": "!newData.exists() || newData.isBoolean()" },
        "handleCrossFactoryTransfer": { ".validate": "!newData.exists() || newData.isBoolean()" },
        "fullControl": { ".validate": "!newData.exists() || newData.isBoolean()" },
        "crossFactoryMaxDistanceKm": { ".validate": "!newData.exists() || (newData.isNumber() && newData.val() >= 0 && newData.val() <= 20000)" },
        "supervisors": {
          "$supervisorId": {
            "ready": {
              ".write": "auth != null && (auth.uid === $supervisorId || root.child('users').child(auth.uid).child('role').val() === 'admin')",
              ".validate": "newData.isBoolean()"
            }
          }
        }
      }
    },

    "shift_ai_logs": {
      ".read": "auth != null",
      ".write": "auth != null && (root.child('users').child(auth.uid).child('role').val() === 'admin' || root.child('users').child(auth.uid).child('role').val() === 'supervisor' || auth.token.role === 'admin')",
      "$shiftId": {
        ".read": "auth != null",
        "$logId": {
          ".read": "auth != null",
          ".write": "auth != null && (root.child('users').child(auth.uid).child('role').val() === 'admin' || auth.token.role === 'admin')",
          "at": { ".validate": "!newData.exists() || newData.isString()" },
          "kind": { ".validate": "!newData.exists() || newData.isString()" },
          "shiftId": { ".validate": "!newData.exists() || newData.isString()" },
          "alertLabel": { ".validate": "!newData.exists() || newData.isString()" },
          "supervisorName": { ".validate": "!newData.exists() || newData.isString()" },
          "supervisorId": { ".validate": "!newData.exists() || newData.isString()" },
          "factory": { ".validate": "!newData.exists() || newData.isString()" },
          "confidence": { ".validate": "!newData.exists() || newData.isNumber()" },
          "reason": { ".validate": "!newData.exists() || newData.isString()" },
          "details": { ".validate": "!newData.exists() || newData.isString()" }
        }
      }
    },

    "shift_presence": {
      ".read": "auth != null",
      ".write": "auth != null",
      "$shiftId": {
        ".read": "auth != null",
        "$supervisorId": {
          ".read": "auth != null",
          ".write": "auth != null && (auth.uid === $supervisorId || root.child('users').child(auth.uid).child('role').val() === 'admin' || auth.token.role === 'admin')",
          "name": { ".validate": "!newData.exists() || newData.isString()" },
          "factory": { ".validate": "!newData.exists() || newData.isString()" },
          "status": { ".validate": "!newData.exists() || newData.isString()" },
          "lastActiveAt": { ".validate": "!newData.exists() || newData.isString()" },
          "inactiveSince": { ".validate": "!newData.exists() || newData.isString()" },
          "confirmRequestedAt": { ".validate": "!newData.exists() || newData.isString()" },
          "confirmExpiresAt": { ".validate": "!newData.exists() || newData.isString()" },
          "confirmedAt": { ".validate": "!newData.exists() || newData.isString()" },
          "joinedAt": { ".validate": "!newData.exists() || newData.isString()" },
          "statusDurationSeconds": { ".validate": "!newData.exists() || newData.isNumber()" }
        }
      }
    },

    "security": {
      ".read": "auth != null && auth.token.role === 'admin'",
      ".write": "auth != null && auth.token.role === 'admin'",
      "logs": {
        ".read": "auth != null && auth.token.role === 'admin'",
        ".write": "auth != null && auth.token.role === 'admin'",
        ".indexOn": ["at", "kind", "fingerprint"]
      },
      "actions": {
        ".read": "auth != null && auth.token.role === 'admin'",
        ".write": "auth != null && auth.token.role === 'admin'",
        ".indexOn": ["at", "kind", "endpoint", "fingerprint"]
      },
      "siem_outbox": {
        ".read": "auth != null && auth.token.role === 'admin'",
        ".write": "auth != null && auth.token.role === 'admin'",
        ".indexOn": ["status", "nextAttemptAt", "exportedAt"]
      },
      "siem_export_status": {
        ".read": "auth != null && auth.token.role === 'admin'",
        ".write": "auth != null && auth.token.role === 'admin'"
      }
    },

    "workers": {
      ".read": "auth != null && auth.token.role === 'admin'",
      ".write": "auth != null && auth.token.role === 'admin'",
      "health": {
        ".read": "auth != null && auth.token.role === 'admin'",
        ".write": "auth != null && auth.token.role === 'admin'"
      }
    },

    "cron_lock": {
      ".read": "auth != null && (root.child('users').child(auth.uid).child('role').val() === 'admin' || auth.token.role === 'admin')",
      ".write": "auth != null && (root.child('users').child(auth.uid).child('role').val() === 'admin' || auth.token.role === 'admin')"
    },

    "factories": {
      ".read": "auth != null",
      "$factoryId": {
        ".read": "auth != null",
        ".write": "auth != null && (root.child('users').child(auth.uid).child('role').val() === 'admin' || auth.token.role === 'admin')",
        "name": { ".validate": "!newData.exists() || newData.isString()" },
        "address": { ".validate": "!newData.exists() || newData.isString()" },
        "location": {
          ".validate": "newData.hasChildren(['lat','lng']) && newData.child('lat').isNumber() && newData.child('lng').isNumber()"
        },
        "aiConfig": {
          ".read": "auth != null",
          ".write": "auth != null && (root.child('users').child(auth.uid).child('role').val() === 'admin' || auth.token.role === 'admin')",
          "enabled": { ".validate": "newData.isBoolean()" },
          "skippedAlertTtlMinutes": { ".validate": "!newData.exists() || (newData.isNumber() && newData.val() >= 1 && newData.val() <= 240)" }
        }
      }
    },

    ".read": false,
    ".write": false
  }
}
